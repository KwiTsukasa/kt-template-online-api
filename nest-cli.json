{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "modules/qqbot/plugins/bangDream/assets/**/*",
        "outDir": "dist"
      },
      {
        "include": "modules/qqbot/plugins/bangDream/static-config/**/*",
        "outDir": "dist"
      }
    ],
    "deleteOutDir": true
  }
}
